# ── Routing: proxy (default) vs direct ────────────────────────────────────────
# EXPO_PUBLIC_USE_PROXY=1  → route through the Vercel key-proxy (keys server-side,
#                            no provider keys in the bundle). DEFAULT — ships this.
# EXPO_PUBLIC_USE_PROXY=0  → talk to providers DIRECTLY using the keys below.
#                            Faster (no proxy hop / cold start) but the keys are
#                            extractable from the app bundle. For latency A/B only.
EXPO_PUBLIC_USE_PROXY=1

# Proxy mode needs these (no provider keys):
EXPO_PUBLIC_PROXY_URL=https://bavarian-api.vibecode.review/api/proxy
EXPO_PUBLIC_APP_KEY=your-app-proxy-token

# Direct mode (USE_PROXY=0) needs these instead — these WILL be baked into the
# build, so only use for testing, never for the App Store build:
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_GROQ_API_KEY=
# EXPO_PUBLIC_MISTRAL_API_KEY=
