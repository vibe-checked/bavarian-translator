# ── Key proxy ─────────────────────────────────────────────────────────────────
# All translation traffic goes through the Vercel proxy, which holds the real
# Gemini/Groq/Mistral keys server-side. The app ships NO provider keys — only the
# proxy URL and a shared app token that gates the proxy (rotatable server-side).
EXPO_PUBLIC_PROXY_URL=https://bavarian-api.vibecode.review/api/proxy
EXPO_PUBLIC_APP_KEY=your-app-proxy-token
